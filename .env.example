# Скопируй в .env и подставь реальные значения. .env закоммичен НЕ будет.
#
# Vercel (serverless, IPv4) → Supabase Session pooler (порт 5432).
# Спецсимволы пароля URL-encode:  +  -> %2B    %  -> %25    /  -> %2F
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<URL_ENCODED_PASSWORD>@aws-1-<REGION>.pooler.supabase.com:5432/postgres"
